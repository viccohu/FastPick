<?xml version="1.0" encoding="UTF-8"?>
<UserControl
    x:Class="FastPick.Controls.ThumbnailItemControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="120"
    d:DesignWidth="100">

    <Grid x:Name="RootGrid"
          Width="100"
          Height="120"
          Background="{StaticResource ElevatedBackgroundBrush}"
          BorderBrush="{StaticResource BorderBrush}"
          BorderThickness="1"
          CornerRadius="4">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <!-- 图片区域 -->
        <Grid Grid.Row="0">
            <Image x:Name="ThumbnailImage"
                   Stretch="Uniform"
                   Margin="4"/>

            <!-- 选中边框 -->
            <Border x:Name="SelectionBorder"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="2"
                    CornerRadius="4"
                    Visibility="Collapsed"/>

            <!-- 预删除角标 -->
            <Border x:Name="DeleteBadge"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{StaticResource DangerBrush}"
                    Width="16"
                    Height="16"
                    CornerRadius="8"
                    Margin="2"
                    Visibility="Collapsed">
                <TextBlock Text="&#xE74D;"
                           FontFamily="Segoe Fluent Icons"
                           FontSize="10"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- 文件类型角标 -->
            <Border x:Name="FileTypeBadge"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource AccentBrush}"
                    Padding="4,2"
                    CornerRadius="2"
                    Margin="2">
                <TextBlock x:Name="FileTypeText"
                           Text="JPG"
                           FontSize="8"
                           Foreground="White"/>
            </Border>
        </Grid>

        <!-- 底部信息栏 -->
        <Grid Grid.Row="1"
              Background="{StaticResource SurfaceBackgroundBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 文件名 -->
            <TextBlock x:Name="FileNameText"
                       Grid.Column="0"
                       Text="IMG_001"
                       FontSize="10"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="4,0"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>

            <!-- 星级 -->
            <TextBlock x:Name="RatingText"
                       Grid.Column="1"
                       Text="&#xE1CF;"
                       FontFamily="Segoe Fluent Icons"
                       FontSize="10"
                       Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,4,0"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>
