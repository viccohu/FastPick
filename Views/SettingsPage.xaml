<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="FastPick.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource PageBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部栏 -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton"
                        Grid.Column="0"
                        Content="&#xE72B;"
                        FontFamily="Segoe Fluent Icons"
                        Style="{StaticResource IconButtonStyle}"
                        Click="BackButton_Click"
                        ToolTipService.ToolTip="返回"/>

                <TextBlock Grid.Column="1"
                           Text="设置"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="16"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </Grid>
        </Border>

        <!-- 内容区域 - 两列布局 -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="24,16,24,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左列：设置 -->
                <StackPanel Grid.Column="0" Spacing="32">

                    <!-- 通用设置 -->
                    <StackPanel Spacing="16">
                        <TextBlock Text="通用设置"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <Border Background="{StaticResource ElevatedBackgroundBrush}"
                                CornerRadius="8"
                                Padding="16,12">
                            <StackPanel Spacing="16">
                                <!-- RAW高分辨率解码 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="RAW 高分辨率解码"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14"/>
                                        <TextBlock Text="开启后，放大 RAW 文件时自动加载高分辨率预览"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="RawHighResDecodeToggle"
                                                  Grid.Column="1"
                                                  OnContent=""
                                                  OffContent=""
                                                  Toggled="RawHighResDecodeToggle_Toggled"/>
                                </Grid>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,4"/>

                                <!-- J+R高清解码切换 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="双文件（j+R）高清解码切换"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14"/>
                                        <TextBlock Text="关闭时高清解码使用 JPG，开启时使用 RAW 文件"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="UseRawForHighResDecodeToggle"
                                                  Grid.Column="1"
                                                  OnContent=""
                                                  OffContent=""
                                                  Toggled="UseRawForHighResDecodeToggle_Toggled"/>
                                </Grid>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,4"/>

                                <!-- 预览加载模式 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="预览加载模式"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14"/>
                                        <TextBlock Text="按需加载：仅放大时加载高清；分级预取：每张图都后台预加载高清"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ComboBox x:Name="PreviewLoadModeComboBox"
                                              Grid.Column="1"
                                              Style="{StaticResource DarkComboBoxStyle}"
                                              SelectionChanged="PreviewLoadModeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="按需加载"/>
                                        <ComboBoxItem Content="分级预取"/>
                                    </ComboBox>
                                </Grid>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,4"/>

                                <!-- 启动时自动加载上次路径 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="启动时自动加载上次路径"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14"/>
                                        <TextBlock Text="打开应用时自动填入上次使用的路径"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AutoLoadLastPathToggle"
                                                  Grid.Column="1"
                                                  OnContent=""
                                                  OffContent=""
                                                  Toggled="AutoLoadLastPathToggle_Toggled"/>
                                </Grid>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,4"/>

                                <!-- 后台持续解码缩略图 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="后台持续解码缩略图"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14"/>
                                        <TextBlock Text="开启后，应用会在后台持续解码所有缩略图，提高浏览流畅度"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="BackgroundThumbnailDecodingToggle"
                                                  Grid.Column="1"
                                                  OnContent=""
                                                  OffContent=""
                                                  Toggled="BackgroundThumbnailDecodingToggle_Toggled"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 导出设置 -->
                    <StackPanel Spacing="16">
                        <TextBlock Text="导出设置"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <Border Background="{StaticResource ElevatedBackgroundBrush}"
                                CornerRadius="8"
                                Padding="16,12">
                            <StackPanel Spacing="16">
                                <!-- JPG文件夹名称 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="JPG 文件夹名称"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14"/>
                                    <TextBox x:Name="JpgFolderNameTextBox"
                                             Grid.Column="1"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             TextChanged="JpgFolderNameTextBox_TextChanged"/>
                                </Grid>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,4"/>

                                <!-- RAW文件夹名称 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="RAW 文件夹名称"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14"/>
                                    <TextBox x:Name="RawFolderNameTextBox"
                                             Grid.Column="1"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             TextChanged="RawFolderNameTextBox_TextChanged"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 删除设置 -->
                    <StackPanel Spacing="16">
                        <TextBlock Text="删除设置"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <Border Background="{StaticResource ElevatedBackgroundBrush}"
                                CornerRadius="8"
                                Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="删除到回收站"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14"/>
                                    <TextBlock Text="关闭后文件将被永久删除，无法恢复"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="DeleteToRecycleBinToggle"
                                              Grid.Column="1"
                                              OnContent=""
                                              OffContent=""
                                              Toggled="DeleteToRecycleBinToggle_Toggled"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- 缓存管理 -->
                    <StackPanel Spacing="16">
                        <TextBlock Text="缓存管理"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <Border Background="{StaticResource ElevatedBackgroundBrush}"
                                CornerRadius="8"
                                Padding="16,12">
                            <StackPanel Spacing="16">
                                <!-- 缓存大小显示 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="缩略图缓存"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14"/>
                                        <TextBlock x:Name="CacheSizeTextBlock"
                                                   Text="计算中..."
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"/>
                                    </StackPanel>
                                </Grid>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,4"/>

                                <!-- 按钮区域 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="OpenCacheFolderButton"
                                            Grid.Column="0"
                                            Content="打开缓存目录"
                                            HorizontalAlignment="Stretch"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="OpenCacheFolderButton_Click"/>
                                    <Button x:Name="ClearCacheButton"
                                            Grid.Column="2"
                                            Content="清除缓存"
                                            HorizontalAlignment="Stretch"
                                            Click="ClearCacheButton_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </StackPanel>

                <!-- 右列：关于 -->
                <StackPanel Grid.Column="2" Spacing="16">
                    <TextBlock Text="关于"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <Border Background="{StaticResource ElevatedBackgroundBrush}"
                            CornerRadius="8"
                            Padding="16,12">
                        <StackPanel Spacing="16">
                            <!-- 应用图标和名称 -->
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <Image Source="ms-appx:///Assets/Square150x150Logo.png"
                                       Width="64"
                                       Height="64"
                                       Stretch="UniformToFill"/>
                                <StackPanel Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="FastPick"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="版本 1.0.0.0"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,4"/>

                            <!-- 快捷键说明 -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="快捷键说明"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="数字键 0-5" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="评级（0=取消评级）" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Delete" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="标记/取消删除" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl+A" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="全选" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="← →" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="切换图片" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Space" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="切换选中状态" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Ctrl+滚轮" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="缩放预览图" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="F" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="适应窗口" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="1:1" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="实际大小" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="R" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="向右旋转" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="L" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="9" Grid.Column="1" Text="向左旋转" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="H" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="10" Grid.Column="1" Text="水平翻转" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="11" Grid.Column="0" Text="V" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,16,4"/>
                                    <TextBlock Grid.Row="11" Grid.Column="1" Text="垂直翻转" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
