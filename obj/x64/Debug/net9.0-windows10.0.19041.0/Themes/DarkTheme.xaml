<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!-- FastPick 深色主题资源字典 -->
    <!-- 基于 Fluent Design 黑色主题规范 -->
    <!-- ============================================ -->

    <!-- 基础色彩资源 -->
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#0D0D0D"/>
    <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ElevatedBackgroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#383838"/>
    <SolidColorBrush x:Key="PressedBackgroundBrush" Color="#444444"/>
    <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="#252525"/>

    <!-- 文本颜色 -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B0B0B0"/>
    <SolidColorBrush x:Key="TexttriBrush" Color="#201f1f"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#666666"/>

    <!-- 强调色 -->
    <SolidColorBrush x:Key="AccentBrush" Color="#27a0dc"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#2693ca"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#3293c4"/>

    <!-- 功能色 -->
    <SolidColorBrush x:Key="DangerBrush" Color="#d40000"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#ff1010"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFB000"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#1089FF"/>
    
    <!-- 删除状态颜色 -->
    <SolidColorBrush x:Key="DeletionBackgroundBrush" Color="#cc3f3f"/>
    <SolidColorBrush x:Key="DeletionBorderBrush" Color="#d10e0e"/>
    <SolidColorBrush x:Key="DeletionTextBrush" Color="#1E1E1E"/>
    
    <!-- 文件类型标签颜色 -->
    <SolidColorBrush x:Key="JpgBrush" Color="#1eefe8"/>      <!-- 蓝色 -->
    <SolidColorBrush x:Key="JpgHoverBrush" Color="#1089FF"/>
    <SolidColorBrush x:Key="RawBrush" Color="#edaa17"/>      <!-- 紫色 -->
    <SolidColorBrush x:Key="RawHoverBrush" Color="#A78BFA"/>
    <SolidColorBrush x:Key="BothBrush" Color="#ea22e3"/>     <!-- 绿色 -->
    <SolidColorBrush x:Key="BothHoverBrush" Color="#34D399"/>

    <!-- 边框和分割线 -->
    <SolidColorBrush x:Key="BorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="BorderHoverBrush" Color="#404040"/>
    <SolidColorBrush x:Key="AccentBorderBrush" Color="#0078D4"/>

    <!-- Acrylic 毛玻璃效果（使用纯色作为回退） -->
    <SolidColorBrush x:Key="AcrylicSurfaceBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="AcrylicElevatedBrush" Color="#2D2D2D"/>

    <!-- ============================================ -->
    <!-- 标题栏按钮样式 -->
    <!-- ============================================ -->
    <Style x:Key="TitleBarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid" 
                          Background="{TemplateBinding Background}"
                          CornerRadius="{TemplateBinding CornerRadius}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{StaticResource HoverBackgroundBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{StaticResource PressedBackgroundBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{StaticResource DisabledBackgroundBrush}"/>
                                        <Setter Target="ContentPresenter.Foreground" Value="{StaticResource TextDisabledBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter x:Name="ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Foreground="{TemplateBinding Foreground}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- 小固定按钮样式 -->
    <!-- ============================================ -->
    <Style x:Key="SmallPinButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="{StaticResource TextDisabledBrush}"/>
    </Style>

