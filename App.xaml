<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="FastPick.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FastPick"
    xmlns:converters="using:FastPick.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    RequestedTheme="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- WinUI 3 基础控件资源 -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- FastPick 深色主题资源 -->
                <ResourceDictionary Source="Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 应用级资源 -->
            <x:Double x:Key="AppFontSize">14</x:Double>

            <!-- 转换器 -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:FileTypeToStringConverter x:Key="FileTypeToStringConverter"/>
            <converters:FileTypeToColorConverter x:Key="FileTypeToColorConverter"/>
            <converters:RatingToStarsConverter x:Key="RatingToStarsConverter"/>
            <converters:RatingToVisibilityConverter x:Key="RatingToVisibilityConverter"/>
            <converters:BoolToDeletionBackgroundConverter x:Key="BoolToDeletionBackgroundConverter"/>

            <!-- 全局文本样式 -->
            <Style x:Key="BodyTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="FontSize" Value="{StaticResource AppFontSize}" />
            </Style>

            <Style x:Key="SecondaryTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                <Setter Property="FontSize" Value="{StaticResource AppFontSize}" />
            </Style>

            <!-- 全局按钮样式 -->
            <Style x:Key="ActionButtonStyle" TargetType="Button">
                <Setter Property="FontSize" Value="{StaticResource AppFontSize}" />
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="CornerRadius" Value="4" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
